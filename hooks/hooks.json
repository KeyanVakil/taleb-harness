{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/barbell.py\""},
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/lindy.py\""},
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/addition_budget.py\""},
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/scope.py\""},
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/no_ghosts.py\""}
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/shell_guard.py\""}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/antifragile.py\""}
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/skin_in_the_game.py\""},
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/fold_discipline.py\""},
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/black_swan.py\""},
          {"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/stressor.py\""}
        ]
      }
    ]
  }
}
